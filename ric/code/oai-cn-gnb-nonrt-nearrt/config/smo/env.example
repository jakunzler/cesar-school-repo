# Fase 3 SMO/OAM scaffold.
# Copy to your shell environment or source manually after editing.

# External checkout of O-RAN SC OAM/SMO.
SMO_OAM_DIR=/path/to/o-ran-sc-oam

# Isolated Docker Compose project name used by scripts/up_smo_lab.sh.
SMO_PROJECT_NAME=oai-smo-lab

# Optional compose layers.
SMO_WITH_NETWORK=0
SMO_WITH_TEIV=0

# Conservative default: abort if Fase 1/Fase 2 containers/processes are active.
SMO_ALLOW_SHARED_HOST=0
