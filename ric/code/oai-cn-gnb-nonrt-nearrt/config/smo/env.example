# Fase 3 SMO lab.
# Copy to your shell environment or source manually after editing.

# Default mode: local. Use external only for a checkout of O-RAN SC OAM/SMO.
SMO_MODE=local
SMO_PROJECT_NAME=oai-smo-lab
SMO_API_PORT=18080

# Local SMO workflow tunables.
O1_SIM_INTERVAL=15
KPM_POLL_INTERVAL=5
ML_WORKFLOW_INTERVAL=20
ML_THROUGHPUT_LOW_KBPS=5
ML_PRB_HIGH_PCT=80

# External O-RAN SC OAM mode.
SMO_OAM_DIR=/path/to/o-ran-sc-oam
SMO_WITH_NETWORK=0
SMO_WITH_TEIV=0
