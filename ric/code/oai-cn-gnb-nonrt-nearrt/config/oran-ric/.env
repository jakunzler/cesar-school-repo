# Overlay Fase 2 — nearRT O-RAN SC (base: vendor/oran-sc-ric/.env)
# Porta E2 36422 para não conflitar com FlexRIC (36421)

SC_RIC_VERSION=i-release

# Redis 5.x evita "got 7 elements in COMMAND reply" no e2mgr/submgr (go-redis antigo)
DBAAS_VER=0.5.0

E2TERM_SCTP_PORT=36422
ORAN_E2_HOST_PORT=36422
# gNB no host: ligar ao e2term pela rede Docker (mais estável que SCTP via port publish)
ORAN_E2_ADDR=10.0.2.10

# A1 Mediator (ric-plt-a1)
A1MEDIATOR_VER=3.2.2
A1MEDIATOR_IP=10.0.2.16
A1MEDIATOR_HOST_PORT=10000
